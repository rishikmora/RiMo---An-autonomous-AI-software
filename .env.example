# RiMo environment — copy to `.env` and fill in. NEVER commit the real .env.

# --- Required ----------------------------------------------------------------
# JWT signing secret. Generate with: openssl rand -hex 32
SECRET_KEY=change_me_to_a_random_32_char_minimum_string

# Anthropic API key — powers all ten agents. Without it the system runs but
# agents cannot reason. Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# --- Database / cache (defaults work with docker-compose) --------------------
POSTGRES_PASSWORD=rimo

# --- Optional: embeddings provider -------------------------------------------
# If set, OpenAI text-embedding-3-small powers semantic memory. If empty, the
# memory service falls back to a deterministic local embedding (lower quality,
# but the system stays fully functional offline).
OPENAI_API_KEY=

# --- Optional: GitHub (required for real repo operations) --------------------
# Create a GitHub App, install it on your repos, and supply these. Without
# them, RiMo plans and writes code in an internal workspace but cannot push,
# open PRs, or merge on real GitHub.
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# --- Runtime -----------------------------------------------------------------
APP_ENV=development
LOG_JSON=true

# --- Security ----------------------------------------------------------------
# Comma-free JSON list of allowed CORS origins (the frontends that may call the
# API). Never use "*" in production. Defaults to localhost:3000.
# CORS_ORIGINS=["https://app.example.com"]
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=14
# Per-IP auth throttle (requests/minute).
RATE_LIMIT_LOGIN_PER_MINUTE=5
RATE_LIMIT_REGISTER_PER_MINUTE=10
# Rate-limit storage; empty uses REDIS_URL. Set memory:// for single-process.
RATELIMIT_STORAGE_URI=

# --- Cost control ------------------------------------------------------------
# Hard per-project spend cap in USD. The orchestrator pauses a project when its
# cumulative model spend reaches this. Set 0 to disable.
MAX_COST_USD_PER_PROJECT=25.0
